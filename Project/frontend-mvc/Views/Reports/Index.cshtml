@model IReadOnlyList<ChartCardViewModel>
@{
    ViewData["Title"] = "Báo cáo";
}
<partial name="_PageHeader" model='("Báo cáo", "Biểu đồ doanh thu, khách hàng, máy, thiết bị, bảo trì và kho.", "Export")' />
<div class="row g-3">
    @foreach (var chart in Model)
    {
        <div class="col-xl-4 col-lg-6">
            <div class="card admin-card h-100">
                <div class="card-header bg-white d-flex justify-content-between">
                    <strong>@chart.Title</strong>
                    <button class="btn btn-sm btn-outline-secondary">Export</button>
                </div>
                <div class="card-body">
                    <div class="apex-chart"
                         data-chart-id="@chart.ElementId"
                         data-type="@chart.Type"
                         data-values='@System.Text.Json.JsonSerializer.Serialize(chart.Values)'
                         data-labels='@System.Text.Json.JsonSerializer.Serialize(chart.Labels)'></div>
                </div>
            </div>
        </div>
    }
</div>
