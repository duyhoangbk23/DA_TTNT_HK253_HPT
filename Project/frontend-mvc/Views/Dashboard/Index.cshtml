@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}
<partial name="_PageHeader" model='("Dashboard", "Toàn cảnh vận hành hệ thống quản lý dịch vụ máy lọc nước thông minh.", "Export")' />

<section class="kpi-grid">
    @foreach (var item in Model.Kpis)
    {
        <partial name="_KpiCard" model="item" />
    }
</section>

<section class="row g-3 mt-1">
    @foreach (var chart in Model.Charts)
    {
        <div class="col-xl-3 col-lg-6">
            <div class="card admin-card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <strong>@chart.Title</strong>
                    <span class="badge text-bg-light">Live</span>
                </div>
                <div class="card-body">
                    <div class="apex-chart"
                         data-chart-id="@chart.ElementId"
                         data-type="@chart.Type"
                         data-values='@System.Text.Json.JsonSerializer.Serialize(chart.Values)'
                         data-labels='@System.Text.Json.JsonSerializer.Serialize(chart.Labels)'></div>
                </div>
            </div>
        </div>
    }
</section>

<section class="row g-3 mt-1">
    <div class="col-xl-3 col-lg-6">
        <div class="card admin-card h-100">
            <div class="card-header bg-white"><strong>Recent Alerts</strong></div>
            <div class="list-group list-group-flush">
                @foreach (var item in Model.RecentAlerts)
                {
                    <div class="list-group-item">
                        <div class="fw-semibold"><i class="bi @item.Icon me-2 text-danger"></i>@item.Title</div>
                        <small class="text-muted">@item.Detail - @item.Time</small>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card admin-card h-100">
            <div class="card-header bg-white"><strong>Recent Maintenance</strong></div>
            <div class="list-group list-group-flush">
                @foreach (var item in Model.RecentMaintenance)
                {
                    <div class="list-group-item d-flex justify-content-between gap-2">
                        <div>
                            <div class="fw-semibold">@item.Customer</div>
                            <small class="text-muted">@item.Technician</small>
                        </div>
                        <span class="badge @UiHelper.WorkOrderBadge(item.Status)">@item.Status</span>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card admin-card h-100">
            <div class="card-header bg-white"><strong>Newest Customers</strong></div>
            <div class="list-group list-group-flush">
                @foreach (var item in Model.NewestCustomers)
                {
                    <div class="list-group-item d-flex align-items-center gap-2">
                        <img class="avatar" src="@item.Avatar" alt="@item.FullName" />
                        <div>
                            <div class="fw-semibold">@item.FullName</div>
                            <small class="text-muted">@item.DeviceCount máy</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-lg-6">
        <div class="card admin-card h-100">
            <div class="card-header bg-white"><strong>System Health</strong></div>
            <div class="list-group list-group-flush">
                @foreach (var item in Model.SystemHealth)
                {
                    <div class="list-group-item">
                        <div class="fw-semibold"><i class="bi @item.Icon me-2 text-success"></i>@item.Title</div>
                        <small class="text-muted">@item.Detail - @item.Time</small>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
