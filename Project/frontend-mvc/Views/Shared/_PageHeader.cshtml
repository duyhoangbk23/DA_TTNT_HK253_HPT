@model (string Title, string Subtitle, string ActionLabel)
<div class="page-header">
    <div>
        <h1>@Model.Title</h1>
        <p>@Model.Subtitle</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary"><i class="bi bi-funnel"></i> Filter</button>
        <button class="btn btn-primary"><i class="bi bi-plus-lg"></i> @Model.ActionLabel</button>
    </div>
</div>
